# En-têtes de sécurité et cache — appliqués par Apache sur l'hébergement OVH.
# (GitHub Pages ignore ce fichier ; les meta CSP des pages servent de filet de sécurité.)

# Pas de listing des répertoires (fuite d'informations sur l'arborescence)
Options -Indexes

# Redirection HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Blocage des fichiers et dossiers cachés (.git, .claude…),
  # sauf .well-known requis pour le renouvellement des certificats SSL
  RewriteRule "(^|/)\.(?!well-known)" - [F]

  # Interdit l'accès public au dossier de documentation interne.
  # docs/ est exclu de la publication, mais des fichiers y subsistent
  # d'anciens déploiements : on bloque l'accès web par précaution.
  RewriteRule ^docs/ - [F]

  # .htpasswd est généré à la volée par le workflow de déploiement GitHub Actions
  # (secret HTACCESS_STATS_PASSWORD) et transféré par FTP dans /www/.htpasswd.
  # En hébergement mutualisé OVH, AuthUserFile requiert le chemin absolu
  # depuis la racine du stockage : /home/<login_ftp>/www/.htpasswd
</IfModule>

# Page de statistiques : protégée par authentification Basic (accès privé).
# La page n'est pas indexée (meta robots noindex + X-Robots-Tag).
# CSP adaptée : autorise l'intégration du tableau de bord Looker Studio en iframe.
<Files "stats.html">
  AuthType Basic
  AuthName "ERPAC — Statistiques (accès privé)"
  AuthUserFile /home/erpacfx/www/.htpasswd
  Require valid-user
  Header always set X-Robots-Tag "noindex, nofollow"
  # Retire la CSP globale (émise par le <IfModule> ci-dessous) pour cette page,
  # puis définit une CSP dédiée autorisant l'iframe Looker Studio.
  # Sans unset, Apache empi lerait deux CSP — le navigateur les fusionne par
  # intersection (la plus restrictive l'emporte) et bloquerait l'iframe.
  Header always unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-src https://lookerstudio.google.com https://datastudio.google.com; frame-ancestors 'none'; object-src 'none'"
</Files>

<IfModule mod_headers.c>
  # Protection clickjacking (impossible en meta, uniquement en en-tête HTTP)
  Header always set X-Frame-Options "DENY"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org https://*.openstreetmap.org https://www.google-analytics.com https://www.googletagmanager.com; media-src 'self'; font-src 'self'; connect-src 'self' https://*.tile.openstreetmap.org https://www.google-analytics.com https://*.google-analytics.com https://analytics.google.com https://www.googletagmanager.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Page 404 personnalisée (Apache/OVH ne la sert pas automatiquement comme GitHub Pages)
ErrorDocument 404 /404.html

# Cache navigateur : court pour HTML/CSS/JS (le Service Worker en stale-while-revalidate
# se charge de la fraîcheur ; un cache court garantit que sa revalidation obtient bien
# les octets à jour après un déploiement), long pour polices et images.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType video/mp4 "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
